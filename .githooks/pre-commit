#!/bin/sh
# 자동 캐시 버스팅 — app.js / style.css 가 바뀌면 index.html의 ?v= 버전을 갱신해
# 브라우저가 새 파일을 자동으로 받게 한다. (분리된 정적 파일 캐시 문제 해결)

# 스테이징된 파일 중 app.js / style.css / index.html 이 있을 때만 동작
changed=$(git diff --cached --name-only)
echo "$changed" | grep -qE '^(app\.js|style\.css|index\.html)$' || exit 0

# 새 버전 = 날짜+시각 (커밋마다 유일)
V=$(date +%Y%m%d%H%M%S)

# index.html의 app.js / style.css 뒤 ?v=... 를 새 버전으로 교체 (없으면 추가)
sed -i -E "s#(href=\"style\.css)(\?v=[0-9A-Za-z]+)?#\1?v=$V#; s#(src=\"app\.js)(\?v=[0-9A-Za-z]+)?#\1?v=$V#" index.html

git add index.html
echo "cache-bust: index.html 버전 갱신 -> v=$V"
